<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center">

        <!-- Кнопка назад -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow"
                android:padding="10dp"
                android:background="@drawable/round_bg"
                android:clickable="true"
                android:focusable="true"
                android:tint="#FFFFFF"
                android:rotation="180" />
        </LinearLayout>

        <!-- Логотип или иконка приложения -->
        <LinearLayout
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="@drawable/logo_circle_bg"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_brain"
                android:tint="#818CF8" />
        </LinearLayout>

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="СОЗДАНИЕ АККАУНТА"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#818CF8"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Регистрация"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="32dp"/>

        <!-- Поле ввода логина -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ЛОГИН"
            android:textSize="12sp"
            android:textColor="#94A3B8"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp"
            android:layout_gravity="start"/>

        <EditText
            android:id="@+id/usernameEditText"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Придумайте логин"
            android:textColorHint="#64748B"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/edittext_modern_bg"
            android:layout_marginBottom="20dp"/>

        <!-- Поле ввода пароля -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПАРОЛЬ"
            android:textSize="12sp"
            android:textColor="#94A3B8"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp"
            android:layout_gravity="start"/>

        <EditText
            android:id="@+id/passwordEditText"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Минимум 6 символов"
            android:textColorHint="#64748B"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/edittext_modern_bg"
            android:layout_marginBottom="20dp"/>

        <!-- Подтверждение пароля -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПОДТВЕРЖДЕНИЕ"
            android:textSize="12sp"
            android:textColor="#94A3B8"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp"
            android:layout_gravity="start"/>

        <EditText
            android:id="@+id/confirmPasswordEditText"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Повторите пароль"
            android:textColorHint="#64748B"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/edittext_modern_bg"
            android:layout_marginBottom="32dp"/>

        <!-- Индикатор сложности пароля (для красоты) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="#334155"
                android:layout_marginEnd="4dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="#334155"
                android:layout_marginEnd="4dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="#334155"/>
        </LinearLayout>

        <!-- Кнопка регистрации -->
        <Button
            android:id="@+id/registerButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="СОЗДАТЬ АККАУНТ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/login_button_bg"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:stateListAnimator="@null"/>

        <!-- Разделитель -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#334155" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ИЛИ"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:paddingHorizontal="16dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#334155" />
        </LinearLayout>

        <!-- Ссылка на вход -->
        <TextView
            android:id="@+id/loginLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Уже есть аккаунт? Войти"
            android:textSize="15sp"
            android:textColor="#818CF8"
            android:textStyle="bold"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Дополнительный текст с условиями -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Продолжая, вы соглашаетесь с условиями использования"
            android:textSize="11sp"
            android:textColor="#64748B"
            android:gravity="center"
            android:lineSpacingExtra="2dp"/>

    </LinearLayout>
</ScrollView>