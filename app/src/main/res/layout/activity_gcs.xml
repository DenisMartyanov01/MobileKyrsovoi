<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fillViewport="true"
    tools:context=".GCSActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="32dp"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:id="@+id/button_to_main">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="4dp"
                        android:src="@drawable/ic_arrow"
                        app:tint="#2196F3" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Шкала Глазго (GCS)"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:gravity="center"
                android:letterSpacing="0.02"
                android:paddingStart="8dp"
                android:paddingEnd="32dp"/>


        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_brain"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/brain" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Шкала комы Глазго"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Оцените уровень сознания пациента по трем критериям: открывание глаз, речевая и двигательная реакция."
                    android:textSize="14sp"
                    android:textColor="#616161"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardUseCompatPadding="true"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Открывание глаз"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/eyesRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/eyesSpontaneous"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Спонтанное (4 балла)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#2196F3"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/eyesToSpeech"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="На речевую команду (3 балла)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#2196F3"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/eyesToPain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="На болевое раздражение (2 балла)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#2196F3"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/eyesNone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Отсутствует (1 балл)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#2196F3" />
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardUseCompatPadding="true"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. Речевая реакция"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/verbalRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/verbalOriented"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ориентирован (5 баллов)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#4CAF50"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/verbalConfused"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Спутанная речь (4 балла)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#4CAF50"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/verbalInappropriate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Неуместные слова (3 балла)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#4CAF50"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/verbalIncomprehensible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Нечленораздельные звуки (2 балла)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#4CAF50"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/verbalNone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Отсутствует (1 балл)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#4CAF50" />
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardUseCompatPadding="true"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. Двигательная реакция"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/motorRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/motorObeys"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Выполняет команды (6 баллов)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#FF9800"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/motorLocalizes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Локализует боль (5 баллов)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#FF9800"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/motorWithdraws"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Отдергивание (4 балла)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#FF9800"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/motorFlexion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Сгибание (3 балла)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#FF9800"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/motorExtension"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Разгибание (2 балла)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#FF9800"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/motorNone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Отсутствует (1 балл)"
                        android:textSize="16sp"
                        android:paddingVertical="12dp"
                        android:buttonTint="#FF9800" />
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/calculateButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Рассчитать GCS"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:gravity="center"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_marginBottom="16dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/resultContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true"
            android:visibility="gone"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Результат оценки GCS"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/totalScoreTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/scoreBreakdownTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#616161"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/interpretationTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:textColor="#212121" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Шкала оценки GCS"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#4CAF50"
                            android:layout_marginEnd="12dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ясное сознание"
                            android:textSize="14sp"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="15 баллов"
                            android:textSize="14sp"
                            android:textColor="#757575"
                            android:gravity="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#FF9800"
                            android:layout_marginEnd="12dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Оглушение"
                            android:textSize="14sp"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="13-14 баллов"
                            android:textSize="14sp"
                            android:textColor="#757575"
                            android:gravity="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#FF5722"
                            android:layout_marginEnd="12dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Сопор"
                            android:textSize="14sp"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="9-12 баллов"
                            android:textSize="14sp"
                            android:textColor="#757575"
                            android:gravity="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#F44336"
                            android:layout_marginEnd="12dp"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Кома"
                            android:textSize="14sp"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="3-8 баллов"
                            android:textSize="14sp"
                            android:textColor="#757575"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>