<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:fillViewport="true"
    tools:context=".GCSActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Хедер с градиентом -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/round_header_bg"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/button_to_main"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow"
                android:padding="10dp"
                android:background="@drawable/round_bg"
                android:clickable="true"
                android:focusable="true"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="GCS"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3-15"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/pill_bg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp" />
        </LinearLayout>

        <!-- Инфо карточка -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E293B"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/circle_bg"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_brain"
                        android:tint="#818CF8" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Шкала комы Глазго"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Оценка уровня сознания"
                        android:textSize="13sp"
                        android:textColor="#94A3B8" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Блок 1: Открывание глаз -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#1E293B"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="0dp">

                <!-- Заголовок -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="24dp"
                        android:background="#818CF8"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ГЛАЗА"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#818CF8"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1-4"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:background="@drawable/pill_gray"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/eyesRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="8dp">

                    <RadioButton
                        android:id="@+id/eyesSpontaneous"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Спонтанное"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#818CF8" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/eyesToSpeech"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="На речевую команду"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#818CF8" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/eyesToPain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="На боль"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#818CF8" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/eyesNone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Нет реакции"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#818CF8" />
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Блок 2: Речевая реакция -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#1E293B"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="24dp"
                        android:background="#F87171"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="РЕЧЬ"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F87171"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1-5"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:background="@drawable/pill_gray"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/verbalRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="8dp">

                    <RadioButton
                        android:id="@+id/verbalOriented"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ориентирован"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#F87171" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/verbalConfused"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Спутанная"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#F87171" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/verbalInappropriate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Неуместные слова"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#F87171" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/verbalIncomprehensible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Нечленораздельно"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#F87171" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/verbalNone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Нет речи"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#F87171" />
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Блок 3: Двигательная реакция -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#1E293B"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="24dp"
                        android:background="#4ADE80"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ДВИЖЕНИЯ"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#4ADE80"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1-6"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:background="@drawable/pill_gray"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/motorRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="8dp">

                    <RadioButton
                        android:id="@+id/motorObeys"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Выполняет команды"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#4ADE80" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/motorLocalizes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Локализует боль"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#4ADE80" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/motorWithdraws"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Отдергивание"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#4ADE80" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/motorFlexion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Сгибание"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#4ADE80" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/motorExtension"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Разгибание"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#4ADE80" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="4dp" />

                    <RadioButton
                        android:id="@+id/motorNone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Нет реакции"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="10dp"
                        android:buttonTint="#4ADE80" />
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Кнопка расчета -->
        <Button
            android:id="@+id/calculateButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="РАССЧИТАТЬ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/round_button_bg"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Результат -->
        <androidx.cardview.widget.CardView
            android:id="@+id/resultContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:visibility="gone"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#312E81">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="РЕЗУЛЬТАТ"
                    android:textSize="12sp"
                    android:textColor="#A5B4FC"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/totalScoreTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="56sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/scoreBreakdownTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#C7D2FE"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/interpretationTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/result_pill"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Легенда -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E293B">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="КЛАССИФИКАЦИЯ"
                    android:textSize="12sp"
                    android:textColor="#94A3B8"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="#4ADE80"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ясное сознание"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="#FBBF24"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Оглушение"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="13-14"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="#F97316"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Сопор"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="9-12"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="#EF4444"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Кома"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3-8"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>